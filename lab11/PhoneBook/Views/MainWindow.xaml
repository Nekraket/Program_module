<Window x:Class="PhoneBook.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Телефонная книга"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#F0F0F0" Height="40">
            <Button Content="Контакты" Command="{Binding ShowContactsCommand}" Margin="5" Padding="10,5" Cursor="Hand"/>
            <Button Content="О программе" Command="{Binding ShowAboutCommand}" Margin="5" Padding="10,5" Cursor="Hand"/>
        </StackPanel>

        <ContentControl Content="{Binding NavigationService.CurrentViewModel}" />
    </DockPanel>
</Window>